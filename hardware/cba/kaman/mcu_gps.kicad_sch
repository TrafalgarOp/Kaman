			)
			(justify top)
		)
		(uuid "586e56d9-8be5-4343-a4d0-61da34106b9a")
	)
	(text_box "This pin is the boot pin and it's pulled up from within the chip so the device will boot into SPI Boot mode and if it's pulled down ROM Bootloader mode (Download mode), This forces the chip to wait for new firmware to be flashed over UART or USB."
		(exclude_from_sim no)
		(at 46.99 54.61 0)
		(size 20.32 6.8117)
		(margins 0.9525 0.9525 0.9525 0.9525)
