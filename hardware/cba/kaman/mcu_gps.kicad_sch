				(color 255 255 0 0.7)
			)
			(justify left top)
		)
		(uuid "52254f00-40df-4f51-b39b-640365fd9f81")
	)
	(text_box "For the USB to USART able to auto download into the esp32 it needs a double NPN transistor structre between DTR,RTS,Boot and enable. This structure is in the schematic of the Dev boards"
		(exclude_from_sim no)
		(at 71.12 25.4 0)
		(size 20.32 5.9938)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
